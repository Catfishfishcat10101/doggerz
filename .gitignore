# -----------------------------
# Doggerz .gitignore
# Stack: Vite + React + Capacitor + Android + Firebase
# -----------------------------

# Node dependencies
node_modules/

# Build output
dist/
dist-ssr/
web-build/
output/
test-results/
coverage/
*.tsbuildinfo

# Tooling caches
.cache/
.vite/
.eslintcache
.stylelintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
play-service-account*.json
google-play-service-account*.json

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDEs / local workspace
.vscode/
.idea/
*.iml
*.suo
*.sln

# Local tooling dirs
.gradle-user-home/
my-app/

# Android / Gradle / Capacitor generated
android/.gradle/
android/.idea/
android/**/build/
android/local.properties
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
android/capacitor-cordova-android-plugins/

# Android signing / release secrets
android/keystore.properties
android/*.jks
android/*.keystore
*.jks
*.keystore

# Android release artifacts
*.apk
*.aab
*.ap_

# Binary / installer leftovers
*.exe
*.msi
*.bak
*.tmp
*.old

# Reports
stats.html
dist/stats.html

# Doggerz generated / temp assets (do not commit)
public/sprites/puppy/
public/sprites/_tmp/

