{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "capacitor.config.json*",
    "vite.config.*",
    "eslint.config.cjs",
    "tailwind.config.*",
    "postcss.config.*"
  ],
  "exclude": ["node_modules", "dist"]
}
