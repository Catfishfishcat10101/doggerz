{
  "appId": "com.doggerz.app",
  "appName": "Doggerz",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "ios": {
    "scrollEnabled": false,
    "contentInset": "never"
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DEFAULT"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "launchFadeOutDuration": 220,
      "backgroundColor": "#090a0fff",
      "showSpinner": true
    },
    "AdMob": {
      "appId": "ca-app-pub-3940256099942544~3347511713"
    }
  }
}
