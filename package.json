{
  "name": "doggerz",
  "version": "2.0.2",
  "main": "src/main.jsx",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "dev:web": "vite",
    "dev:web:host": "vite --host 127.0.0.1 --port 5173",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:jest": "jest --config jest.config.cjs",
    "test:jest:watch": "jest --config jest.config.cjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "build": "vite build",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "images:optimize": "node scripts/optimize-images.js",
    "audio:optimize": "node scripts/optimize-audio.js",
    "audio:sfx": "node scripts/generate-sfx.js",
    "backgrounds:make": "node scripts/make-backgrounds.mjs",
    "backgrounds:wide": "node scripts/generate-wide-backyard.js",
    "sprites:generate": "node scripts/generate-sprites.js",
    "sprites:pack-atlas": "node scripts/pack-atlas-to-sprites.js",
    "sprites:pack-custom": "node scripts/pack-jr-custom-atlas.js",
    "sprites:build": "npm run sprites:generate && npm run sprites:pack-atlas",
    "sprites:frames:validate": "node scripts/validate-sprite-frames.js",
    "sprites:jrt:base": "node scripts/generate-jack-russell-base-sprites.js",
    "sprites:jr": "node scripts/generate-jr-pixi-sheets.js",
    "sprites:jr:action": "node scripts/generate-jr-action-sheet.js",
    "sprites:check": "node scripts/validate-sprites.js",
    "postinstall": "patch-package",
    "preflight": "node scripts/check-ts-nocheck.js && node scripts/preflight.js && npm run assets:verify",
    "preflight:strict": "node scripts/preflight.js --strict && npm run sprites:check",
    "ci:verify": "npm run lint && npm run typecheck && npm run build && npm run preflight",
    "preview": "vite preview",
    "preview:host": "vite preview --host 127.0.0.1 --port 4173",
    "lint-staged:fixup": "node scripts/add-lintstaged.js",
    "check": "npm run format:check && npm run lint && npm run build",
    "assets:verify": "node scripts/verify-web-assets.js",
    "release:bump": "node scripts/bump-version.js"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "8.0.2",
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "^7.0.4",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "8.0.1",
    "@pixi/react": "^7.1.2",
    "@reduxjs/toolkit": "^2.10.1",
    "@revenuecat/purchases-capacitor": "^12.0.5",
    "@tanstack/react-query": "^5.90.21",
    "firebase": "^11.10.0",
    "pixi.js": "^7.4.3",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.25.4",
    "@capacitor/cli": "8.0.2",
    "@eslint/js": "^9.18.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.27",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^30.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-define": "^2.1.4",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "eslint": "^9.18.0",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "ffmpeg-static": "^5.2.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "rollup": "^4.56.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "@firebase/webchannel-wrapper": "1.0.4",
    "@capacitor/cli": {
      "tar": "^7.5.6"
    }
  }
}
