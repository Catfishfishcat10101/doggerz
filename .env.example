# Landing trailer controls
# Optional embedded player URL (example: https://www.youtube.com/embed/VIDEO_ID)
VITE_TRAILER_EMBED_URL=

# Fallback external URL when no embed URL is set
VITE_TRAILER_URL=https://doggerz.app

# Billing / pre-registration reward
VITE_PRE_REG_PRODUCT_ID=pre_reg_bonus_kit
VITE_PRE_REG_GIFT_COINS=500
VITE_ENABLE_RUNTIME_LOGGING=false
VITE_ENABLE_PROD_WARNINGS=false
VITE_SUPPRESS_ENV_MISSING_WARNINGS=false
VITE_ASSET_BASE=

# Existing weather hooks use these keys
VITE_OPENWEATHER_API_KEY=
VITE_WEATHER_DEFAULT_ZIP=10001

# Firebase (required for auth/cloud sync features)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
